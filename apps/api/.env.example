NODE_ENV=development
PORT=3002
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roi?schema=public"
JWT_SECRET="replace-with-a-strong-secret-at-least-32-chars"
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY="replace-with-a-strong-32-char-key"
JWT_EXPIRES_IN="1h"
BCRYPT_SALT_ROUNDS=12
CORS_ORIGINS="http://localhost:3100,http://127.0.0.1:3100,http://localhost:3200,http://127.0.0.1:3200,http://localhost:3201,http://127.0.0.1:3201,http://localhost:3300,http://127.0.0.1:3300,http://localhost:3400,http://127.0.0.1:3400,http://localhost:3401,http://127.0.0.1:3401"
REALTIME_ALLOWED_ORIGINS=""
TRUST_PROXY=false
INTERNAL_NETWORK_ENFORCE=false
ENABLE_REQUEST_LOGS=true
REQUEST_LOG_EXCLUDE_HEALTH=true
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
PUBLIC_RATE_LIMIT_MAX=30
PUBLIC_MENU_RATE_LIMIT_MAX=90
PUBLIC_ORDER_IDEMPOTENCY_WINDOW_MINUTES=15
INTEGRATION_TEST_RATE_LIMIT_MAX=15
READINESS_DB_TIMEOUT_MS=2500
ERROR_TRACKING_DSN=""
